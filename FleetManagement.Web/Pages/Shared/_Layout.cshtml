@* _Layout.cshtml Fleet Management SaaS con sidebar colorido y iconos redondos *@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fleet Management</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
        }

        /* SIDEBAR */
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #1e293b, #0f172a);
            padding: 1rem;
        }

            .sidebar h4 {
                font-weight: 600;
                color: #fff;
            }

            .sidebar .nav-link {
                display: flex;
                align-items: center;
                gap: 0.8rem;
                color: #cbd5f5;
                border-radius: 12px;
                margin-bottom: 8px;
                padding: 10px 15px;
                transition: all 0.2s;
            }

                .sidebar .nav-link:hover {
                    background-color: #1e40af;
                    color: #fff;
                }

                .sidebar .nav-link.active {
                    background-color: #2563eb;
                    color: #fff;
                    font-weight: 500;
                }

                .sidebar .nav-link span.icon {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    background-color: #3b82f6;
                    color: #fff;
                    font-size: 0.9rem;
                }

        /* TOPBAR */
        .topbar {
            background-color: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 6px rgba(0,0,0,0.04);
        }

        /* CONTENT */
        .content {
            padding: 25px;
        }

        /* CARDS */
        .card {
            border-radius: 14px;
            border: none;
            box-shadow: 0 6px 16px rgba(0,0,0,0.06);
        }

            .card .card-body {
                padding: 1.5rem;
            }

            .card .card-title {
                font-weight: 600;
                font-size: 1.1rem;
                color: #111827;
            }

            .card .card-text {
                font-size: 1.5rem;
                font-weight: 700;
            }

        /* TABLE */
        .table {
            border-radius: 10px;
            overflow: hidden;
        }

            .table thead {
                background-color: #f1f5f9;
            }

        /* BUTTONS */
        .btn {
            border-radius: 8px;
        }

        /* BADGES */
        .badge {
            border-radius: 6px;
            padding: 5px 8px;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <nav class="col-md-2 sidebar d-none d-md-block">
                <h4 class="mb-4">🚛 Fleet</h4>

                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">
                            <span class="icon">📊</span> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Companies/Index">
                            <span class="icon">🏢</span> Empresas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Drivers/Index">
                            <span class="icon">👨‍✈️</span> Conductores
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Vehicles/Index">
                            <span class="icon">🚗</span> Vehículos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Fuel/Index">
                            <span class="icon">⛽</span> Combustible
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Maintenance/Index">
                            <span class="icon">🛠️</span> Mantenimiento
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Main -->
            <main class="col-md-10 ms-sm-auto px-md-4">

                <!-- Topbar -->
                <div class="topbar">
                    <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted">👤 Admin</span>
                    </div>
                </div>

                <!-- Content -->
                <div class="content">
                    @RenderBody()
                </div>

            </main>
        </div>
    </div>

    <!-- Scripts -->
    @RenderSection("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>