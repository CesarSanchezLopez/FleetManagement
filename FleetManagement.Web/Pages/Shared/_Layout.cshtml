@* _Layout.cshtml para Fleet Management SPA con modales *@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fleet Management</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }

        /* Sidebar */
        .sidebar {
            min-height: 100vh;
            background-color: #343a40;
            padding: 1rem;
        }

            .sidebar .nav-link {
                color: #adb5bd;
                border-radius: 6px;
                margin-bottom: 5px;
                padding: 10px 15px;
                transition: 0.2s;
            }

                .sidebar .nav-link:hover {
                    background-color: #495057;
                    color: #fff;
                }

                .sidebar .nav-link.active {
                    background-color: #0d6efd;
                    color: #fff;
                }

        /* Topbar */
        .topbar {
            background-color: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Main content */
        .content {
            padding: 20px;
        }

        /* Card & table styling */
        .card {
            border-radius: 10px;
        }

        .table th, .table td {
            vertical-align: middle;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <nav class="col-md-2 sidebar d-none d-md-block">
                <h4 class="text-white mb-4">🚛 Fleet</h4>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">📊 Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Companies/Index">🏢 Empresas</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Drivers/Index">👨‍✈️ Conductores</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Vehicles/Index">🚗 Vehículos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Fuel/Index">⛽ Combustible</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Maintenance/Index">🛠️ Mantenimiento</a></li>
                </ul>
            </nav>

            <!-- Main content -->
            <main class="col-md-10 ms-sm-auto px-md-4">
                <!-- Topbar -->
                <div class="topbar">
                    <h5 class="mb-0">@ViewData["Title"]</h5>
                    <div><span class="text-muted">👤 Admin</span></div>
                </div>

                <!-- Content -->
                <div class="content">
                    @RenderBody()
                </div>
            </main>

        </div>
    </div>

    <!-- Scripts section -->
    @RenderSection("Scripts", required: false)

    <!-- Bootstrap JS Bundle (Popper incluido, necesario para modales) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>