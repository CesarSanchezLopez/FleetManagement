@page
@model FleetManagement.Web.Pages.Drivers.CreateModel
@{
    ViewData["Title"] = "Crear Conductor";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">➕ Crear Conductor</h4>
        </div>

        <div class="card-body">

            <form method="post">

                <div class="mb-3">
                    <label asp-for="Driver.FirstName" class="form-label"></label>
                    <input asp-for="Driver.FirstName" class="form-control" placeholder="Nombre" />
                </div>

                <div class="mb-3">
                    <label asp-for="Driver.LastName" class="form-label"></label>
                    <input asp-for="Driver.LastName" class="form-control" placeholder="Apellido" />
                </div>

                <div class="mb-3">
                    <label asp-for="Driver.CompanyId" class="form-label">Empresa</label>
                    <select asp-for="Driver.CompanyId" class="form-select" asp-items="Model.CompaniesSelectList">
                        <option value="">-- Selecciona Empresa --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Driver.LicenseNumber" class="form-label"></label>
                    <input asp-for="Driver.LicenseNumber" class="form-control" placeholder="Número de Licencia" />
                </div>

                <div class="mb-3">
                    <label asp-for="Driver.LicenseExpiration" class="form-label"></label>
                    <input asp-for="Driver.LicenseExpiration" class="form-control" type="date" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">💾 Guardar</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>

            </form>

        </div>
    </div>

</div>