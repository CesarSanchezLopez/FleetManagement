@page
@model FleetManagement.Web.Pages.Drivers.IndexModel
@{
    ViewData["Title"] = "Conductores";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👨‍✈️ Conductores</h2>
        <a class="btn btn-primary" asp-page="Create">+ Nuevo Conductor</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Empresa</th>
                        <th>Licencia</th>
                        <th>Expiración</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Drivers.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No hay conductores registrados.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var driver in Model.Drivers)
                        {
                            <tr>
                                <td>@driver.FirstName</td>
                                <td>@driver.LastName</td>
                                <td>@driver.CompanyName</td>
                                <td>@driver.LicenseNumber</td>
                                <td>@driver.LicenseExpiration.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-warning me-1"
                                       asp-page="Edit"
                                       asp-route-id="@driver.Id">✏️</a>
                                    <a class="btn btn-sm btn-outline-danger"
                                       asp-page="Delete"
                                       asp-route-id="@driver.Id">🗑️</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>