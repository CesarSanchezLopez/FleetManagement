@page
@model FleetManagement.Web.Pages.Drivers.IndexModel
@{
    ViewData["Title"] = "Conductores";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>👨‍✈️ Conductores</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
            + Nuevo
        </button>
    </div>

    <div class="card shadow-sm">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Empresa</th>
                    <th>Licencia</th>
                    <th>Vence</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var d in Model.Drivers)
                {
                    <tr>
                        <td>@d.FirstName @d.LastName</td>
                        <td>@d.CompanyName</td>
                        <td>@d.LicenseNumber</td>
                        <td>@d.LicenseExpiration.ToShortDateString()</td>
                        <td class="text-end">

                            <button class="btn btn-sm btn-warning"
                                    onclick="edit('@d.Id','@d.FirstName','@d.LastName','@d.LicenseNumber','@d.LicenseExpiration.ToString("yyyy-MM-dd")','@d.CompanyId')">
                                ✏️
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    onclick="del('@d.Id','@d.FirstName @d.LastName')">
                                🗑️
                            </button>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- CREATE -->
<div class="modal fade" id="createModal">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Create" class="modal-content">
            <div class="modal-header"><h5>Nuevo</h5></div>
            <div class="modal-body">

                <input asp-for="Input.FirstName" class="form-control mb-2" placeholder="Nombre" />
                <input asp-for="Input.LastName" class="form-control mb-2" placeholder="Apellido" />
                <input asp-for="Input.LicenseNumber" class="form-control mb-2" placeholder="Licencia" />
                <input asp-for="Input.LicenseExpiration" type="date" class="form-control mb-2" />

                <select asp-for="Input.CompanyId" class="form-select">
                    <option value="">Empresa</option>
                    @foreach (var c in Model.Companies)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>

            </div>
            <div class="modal-footer">
                <button class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT -->
<div class="modal fade" id="editModal">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit" class="modal-content">
            <input type="hidden" asp-for="Input.Id" id="eId" />

            <div class="modal-body">
                <input id="eF" asp-for="Input.FirstName" class="form-control mb-2" />
                <input id="eL" asp-for="Input.LastName" class="form-control mb-2" />
                <input id="eN" asp-for="Input.LicenseNumber" class="form-control mb-2" />
                <input id="eD" asp-for="Input.LicenseExpiration" type="date" class="form-control mb-2" />

                <select id="eC" asp-for="Input.CompanyId" class="form-select">
                    @foreach (var c in Model.Companies)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="modal-footer">
                <button class="btn btn-warning">Actualizar</button>
            </div>
        </form>
    </div>
</div>

<!-- DELETE -->
<div class="modal fade" id="deleteModal">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Delete" class="modal-content">
            <input type="hidden" asp-for="Input.Id" id="dId" />

            <div class="modal-body">
                <p>Eliminar <strong id="dName"></strong> ?</p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-danger">Eliminar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function edit(id,f,l,n,d,c){
            eId.value=id;
            eF.value=f;
            eL.value=l;
            eN.value=n;
            eD.value=d;
            eC.value=c;
            new bootstrap.Modal(editModal).show();
        }

        function del(id,name){
            dId.value=id;
            dName.innerText=name;
            new bootstrap.Modal(deleteModal).show();
        }
    </script>
}