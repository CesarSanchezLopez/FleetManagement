@page
@model FleetManagement.Web.Pages.Vehicles.IndexModel
@{
    ViewData["Title"] = "Vehículos";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🚗 Vehículos</h2>
        <a class="btn btn-primary" asp-page="Create">+ Nuevo Vehículo</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Matrícula</th>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>Año</th>
                        <th>VIN</th>
                        <th>Empresa</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Vehicles.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No hay vehículos registrados.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var vehicle in Model.Vehicles)
                        {
                            <tr>
                                <td>@vehicle.LicensePlate</td>
                                <td>@vehicle.Brand</td>
                                <td>@vehicle.Model</td>
                                <td>@vehicle.Year</td>
                                <td>@vehicle.VIN</td>
                                <td>@vehicle.CompanyName</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-warning me-1"
                                       asp-page="Edit"
                                       asp-route-id="@vehicle.Id">✏️</a>
                                    <a class="btn btn-sm btn-outline-danger"
                                       asp-page="Delete"
                                       asp-route-id="@vehicle.Id">🗑️</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>