@page "{id:guid}"
@model FleetManagement.Web.Pages.Companies.EditModel
@{
    ViewData["Title"] = "Editar Empresa";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">✏️ Editar Empresa</h4>
        </div>

        <div class="card-body">

            <form method="post">

                <input type="hidden" asp-for="Company.Id" />

                <div class="mb-3">
                    <label asp-for="Company.Name" class="form-label"></label>
                    <input asp-for="Company.Name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Company.Nit" class="form-label"></label>
                    <input asp-for="Company.Nit" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Company.Address" class="form-label"></label>
                    <input asp-for="Company.Address" class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        💾 Actualizar
                    </button>

                    <a asp-page="Index" class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>